# Copy to .env and fill in real values. Never commit .env to git.

# JWT
JWT_SECRET=your-256-bit-secret-here

# Product DB
PRODUCT_DB_USER=product_user
PRODUCT_DB_PASSWORD=product_pass

# Order DB
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=order_pass

# Forecast DB
FORECAST_DB_USER=forecast_user
FORECAST_DB_PASSWORD=forecast_pass
